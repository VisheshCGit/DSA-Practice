#include <iostream>
#include <stack>
#include <unordered_map>
using namespace std;

class FreqStack{
    unordered_map<int,int> freq; //stores current frequency of every element
    unordered_map<int,stack<int>> group; //stores elements having the same frequency
    int maxFreq;

public:
    FreqStack(){
        maxFreq=0;
    }

    void push(int val){
        freq[val]++;

        maxFreq=max(maxFreq,freq[val]);

        group[freq[val]].push(val);
    }

    int pop(){
        int ans=group[maxFreq].top();
        group[maxFreq].pop();

        freq[ans]--;

        if(freq[ans]==0)
            freq.erase(ans);

        if(group[maxFreq].empty()){
            group.erase(maxFreq);
            maxFreq--;
        }

        return ans;
    }
};

int main(){
    FreqStack st;

    st.push(5);
    st.push(7);
    st.push(5);
    st.push(7);
    st.push(4);
    st.push(5);

    cout<<st.pop()<<endl;
    cout<<st.pop()<<endl;
    cout<<st.pop()<<endl;
    cout<<st.pop()<<endl;

    return 0;
}